{
  "power_mode": "balanced",
  "workspace_root": ".",
  "source_mode": "amanoba_live_db",
  "state_db_path": ".course-quality/state.sqlite3",
  "backups_dir": ".course-quality/backups",
  "reports_dir": ".course-quality/reports",
  "scan_interval_seconds": 60,
  "scan_globs": [
    "**/*.json"
  ],
  "ignore_dirs": [
    ".course-quality",
    "__pycache__"
  ],
  "apply_fixes": true,
  "fix_questions": true,
  "fix_lessons": true,
  "max_attempts_per_task": 5,
  "feed_limit": 25,
  "queue_check_interval_seconds": 60,
  "idle_sleep_seconds": 60,
  "post_task_sleep_seconds": 60,
  "action_feed_limit": 3,
  "max_task_runtime_seconds": 600,
  "runtime": {
    "provider_order": [
      "mlx",
      "ollama"
    ],
    "writer_provider_order": [
      "mlx",
      "ollama"
    ],
    "ollama": {
      "endpoint": "http://127.0.0.1:11434",
      "model": "llama3.2:3b",
      "fallback_models": [
        "qwen2.5:3b",
        "llama3.2:1b"
      ],
      "timeout": 180,
      "temperature": 0.1,
      "num_predict": 384,
      "lesson_num_predict": 1024,
      "question_num_predict": 384,
      "num_ctx": 2048,
      "num_thread": 2
    },
    "mlx": {
      "model": "/Users/chappie/.cache/huggingface/hub/models--mlx-community--Apertus-8B-Instruct-2509-8bit/snapshots/fa890d8c0f9a9e35630116daa2cebe72a453c882",
      "python_bin": "/usr/bin/python3",
      "timeout": 300,
      "health_timeout": 15,
      "cooldown_seconds": 600,
      "max_consecutive_failures": 2,
      "max_tokens": 768,
      "lesson_max_tokens": 1400,
      "question_max_tokens": 768,
      "fast_mlx_port": 8501
    },
    "openai": {
      "api_key_env": "OPENAI_API_KEY",
      "model": "gpt-5.2"
    },
    "resident_creator_roles": [
      {"name": "DRAFTER", "host": "127.0.0.1", "port": 8080, "model_label": "Gemma 3 270M", "family": "MLX quantized local model", "model": "/Users/chappie/.cache/huggingface/hub/models--mlx-community--gemma-3-270m-it-4bit/snapshots/ff1143e3a10547c9f2129e94ca37059b096b23f4", "launch_label": "com.amanoba.coursequality.role.drafter", "warm_prompt": "Reply with exactly: READY"},
      {"name": "WRITER", "host": "127.0.0.1", "port": 8081, "model_label": "Granite 4.0 350M (H)", "family": "MLX quantized local model", "model": "/Users/chappie/.cache/huggingface/hub/models--mlx-community--granite-4.0-h-350m-8bit/snapshots/754e5ae403ffa03922e36332ca5e528f14464a1b", "launch_label": "com.amanoba.coursequality.role.writer", "warm_prompt": "Reply with exactly: READY"},
      {"name": "JUDGE", "host": "127.0.0.1", "port": 8082, "model_label": "Qwen 2.5 0.5B", "family": "MLX quantized local model", "model": "/Users/chappie/.cache/huggingface/hub/models--mlx-community--Qwen2.5-0.5B-Instruct-4bit/snapshots/a5339a4131f135d0fdc6a5c8b5bbed2753bbe0f3", "launch_label": "com.amanoba.coursequality.role.judge", "warm_prompt": "Reply with exactly: READY"}
    ]
  },
  "live": {
    "app_root": "/Users/chappie/Projects/amanoba",
    "bridge_script": "scripts/course-quality-live-bridge.ts",
    "actor": "course-quality-daemon",
    "batch_size": 100,
    "batch_passes": 8,
    "bridge_timeout_seconds": 120
  },
  "dashboard": {
    "host": "127.0.0.1",
    "port": 8765
  },
  "watchdog": {
    "check_interval_seconds": 60,
    "full_restart_interval_seconds": 10800,
    "quarantine_after_failures": 2,
    "primary_writer_provider": "mlx",
    "worker_process_timeout_seconds": 600,
    "worker_progress_timeout_seconds": 600,
    "worker_backlog_timeout_seconds": 600,
    "mlx_process_timeout_seconds": 600,
    "dashboard_request_timeout_seconds": 8,
    "ollama_request_timeout_seconds": 5
  }
