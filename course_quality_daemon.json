{
  "power_mode": "balanced",
  "workspace_root": ".",
  "source_mode": "amanoba_live_db",
  "state_db_path": ".course-quality/state.sqlite3",
  "backups_dir": ".course-quality/backups",
  "reports_dir": ".course-quality/reports",
  "scan_interval_seconds": 60,
  "scan_globs": [
    "**/*.json"
  ],
  "ignore_dirs": [
    ".course-quality",
    "__pycache__"
  ],
  "apply_fixes": true,
  "fix_questions": true,
  "fix_lessons": true,
  "max_attempts_per_task": 5,
  "feed_limit": 25,
  "queue_check_interval_seconds": 60,
  "idle_sleep_seconds": 60,
  "post_task_sleep_seconds": 60,
  "action_feed_limit": 3,
  "max_task_runtime_seconds": 600,
  "runtime": {
    "creator_pipeline": {
      "drafter": {
        "tool": "MLX-LM",
        "model": "$HOME/.cache/huggingface/hub/models--mlx-community--gemma-3-270m-it-4bit/snapshots/ff1143e3a10547c9f2129e94ca37059b096b23f4",
        "label": "Gemma 3 270M",
        "statusLabel": "drafting",
        "description": "Breaks source into atomic pieces and initial structure.",
        "provider": "mlx",
        "resident_server": true,
        "server_host": "127.0.0.1",
        "server_port": 8080,
        "server_startup_timeout": 240,
        "health_timeout": 45
      },
      "writer": {
        "tool": "MLX-LM",
        "model": "$HOME/.cache/huggingface/hub/models--mlx-community--granite-4.0-h-350m-8bit/snapshots/754e5ae403ffa03922e36332ca5e528f14464a1b",
        "label": "Granite 4.0 350M (H)",
        "statusLabel": "enriching",
        "description": "Expands the draft into fluent, structured content.",
        "lesson_max_tokens": 384,
        "question_max_tokens": 384,
        "provider": "mlx",
        "resident_server": true,
        "server_host": "127.0.0.1",
        "server_port": 8081,
        "server_startup_timeout": 240,
        "health_timeout": 45
      },
      "judge": {
        "tool": "MLX-LM",
        "model": "$HOME/.cache/huggingface/hub/models--mlx-community--Qwen2.5-0.5B-Instruct-4bit/snapshots/a5339a4131f135d0fdc6a5c8b5bbed2753bbe0f3",
        "label": "Qwen 2.5 0.5B",
        "statusLabel": "judging",
        "description": "Checks structure, language, and quality gates.",
        "provider": "mlx",
        "resident_server": true,
        "server_host": "127.0.0.1",
        "server_port": 8082,
        "server_startup_timeout": 240,
        "health_timeout": 45
      }
    },
    "resident_creator_roles": [
      {
        "name": "DRAFTER",
        "host": "127.0.0.1",
        "port": 8080,
        "model": "$HOME/.cache/huggingface/hub/models--mlx-community--gemma-3-270m-it-4bit/snapshots/ff1143e3a10547c9f2129e94ca37059b096b23f4",
        "model_label": "Gemma 3 270M",
        "family": "MLX quantized local model",
        "launch_label": "com.amanoba.coursequality.role.drafter",
        "warm_prompt": "Reply with exactly: READY"
      },
      {
        "name": "WRITER",
        "host": "127.0.0.1",
        "port": 8081,
        "model": "$HOME/.cache/huggingface/hub/models--mlx-community--granite-4.0-h-350m-8bit/snapshots/754e5ae403ffa03922e36332ca5e528f14464a1b",
        "model_label": "Granite 4.0 350M (H)",
        "family": "MLX quantized local model",
        "launch_label": "com.amanoba.coursequality.role.writer",
        "warm_prompt": "Reply with exactly: READY"
      },
      {
        "name": "JUDGE",
        "host": "127.0.0.1",
        "port": 8082,
        "model": "$HOME/.cache/huggingface/hub/models--mlx-community--Qwen2.5-0.5B-Instruct-4bit/snapshots/a5339a4131f135d0fdc6a5c8b5bbed2753bbe0f3",
        "model_label": "Qwen 2.5 0.5B",
        "family": "MLX quantized local model",
        "launch_label": "com.amanoba.coursequality.role.judge",
        "warm_prompt": "Reply with exactly: READY"
      }
    ],
    "provider_order": [
      "mlx",
      "ollama"
    ],
    "writer_provider_order": [
      "mlx",
      "ollama"
    ],
    "ollama": {
      "endpoint": "http://127.0.0.1:11434",
      "model": "llama3.2:3b",
      "fallback_models": [
        "qwen2.5:3b",
        "llama3.2:1b"
      ],
      "timeout": 180,
      "temperature": 0.1,
      "num_predict": 384,
      "lesson_num_predict": 384,
      "question_num_predict": 384,
      "num_ctx": 2048,
      "num_thread": 2
    },
    "mlx": {
      "model": "$HOME/.cache/huggingface/hub/models--mlx-community--Apertus-8B-Instruct-2509-8bit/snapshots/fa890d8c0f9a9e35630116daa2cebe72a453c882",
      "python_bin": "$HOME/Projects/amanoba_courses/.venv-mlx/bin/python",
      "timeout": 180,
      "health_timeout": 45,
      "cooldown_seconds": 600,
      "max_consecutive_failures": 2,
      "max_tokens": 384,
      "lesson_max_tokens": 384,
      "question_max_tokens": 384,
      "fast_mlx_port": null
    },
    "openai": {
      "api_key_env": "OPENAI_API_KEY",
      "model": "gpt-5.2"
    }
  },
  "live": {
    "app_root": "$HOME/Projects/amanoba",
    "bridge_script": "scripts/course-quality-live-bridge.ts",
    "actor": "course-quality-daemon",
    "batch_size": 25,
    "batch_passes": 8,
    "bridge_timeout_seconds": 120
  },
  "dashboard": {
    "host": "127.0.0.1",
    "port": 8765
  },
  "watchdog": {
    "check_interval_seconds": 60,
    "full_restart_interval_seconds": 10800,
    "quarantine_after_failures": 2,
    "primary_writer_provider": "mlx",
    "worker_process_timeout_seconds": 300,
    "worker_progress_timeout_seconds": 120,
    "worker_backlog_timeout_seconds": 120,
    "mlx_process_timeout_seconds": 120,
    "dashboard_request_timeout_seconds": 8,
    "ollama_request_timeout_seconds": 5
  }
}
