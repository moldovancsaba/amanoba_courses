{
  "power_mode": "balanced",
  "workspace_root": ".",
  "source_mode": "amanoba_live_db",
  "state_db_path": ".course-quality/state.sqlite3",
  "backups_dir": ".course-quality/backups",
  "reports_dir": ".course-quality/reports",
  "scan_interval_seconds": 300,
  "scan_globs": [
    "**/*.json"
  ],
  "ignore_dirs": [
    ".course-quality",
    "__pycache__"
  ],
  "apply_fixes": true,
  "fix_questions": true,
  "fix_lessons": true,
  "max_attempts_per_task": 5,
  "feed_limit": 25,
  "queue_check_interval_seconds": 300,
  "idle_sleep_seconds": 300,
  "post_task_sleep_seconds": 300,
  "action_feed_limit": 3,
  "max_task_runtime_seconds": 60,
  "runtime": {
    "provider_order": ["ollama", "mlx"],
    "ollama": {
      "endpoint": "http://127.0.0.1:11434",
      "model": "llama3.2:3b",
      "temperature": 0.1,
      "num_predict": 384,
      "num_ctx": 2048,
      "num_thread": 2
    },
    "mlx": {
      "model": "/Users/moldovancsaba/.cache/huggingface/hub/models--mlx-community--Apertus-8B-Instruct-2509-4bit/snapshots/c5e6ae2e52c4149f36cb8e47b7ab1489ef885fed",
      "timeout": 120,
      "max_tokens": 768
    },
    "openai": {
      "api_key_env": "OPENAI_API_KEY",
      "model": "gpt-5.2"
    }
  },
  "live": {
    "app_root": "/Users/moldovancsaba/Projects/amanoba",
    "bridge_script": "scripts/course-quality-live-bridge.ts",
    "actor": "course-quality-daemon",
    "batch_size": 25,
    "batch_passes": 8,
    "bridge_timeout_seconds": 120
  },
  "dashboard": {
    "host": "127.0.0.1",
    "port": 8765
  },
  "watchdog": {
    "check_interval_seconds": 600,
    "full_restart_interval_seconds": 10800,
    "quarantine_after_failures": 2,
    "worker_process_timeout_seconds": 180,
    "dashboard_request_timeout_seconds": 8,
    "ollama_request_timeout_seconds": 5
  }
}
