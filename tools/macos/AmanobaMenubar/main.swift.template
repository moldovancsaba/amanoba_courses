import AppKit
import Foundation

final class AmanobaMenubarApp: NSObject, NSApplicationDelegate {
    private enum IndicatorState {
        case idle
        case working
        case error

        var title: String {
            switch self {
            case .idle:
                return "⚪ AQ"
            case .working:
                return "🟢 AQ"
            case .error:
                return "🔴 AQ"
            }
        }
    }

    private let statusItem = NSStatusBar.system.statusItem(withLength: NSStatusItem.variableLength)
    private let menu = NSMenu()
    private let productItem = NSMenuItem(title: "Amanoba v__APP_VERSION__", action: nil, keyEquivalent: "")
    private let healthItem = NSMenuItem(title: "Health: checking...", action: nil, keyEquivalent: "")
    private let powerItem = NSMenuItem(title: "Power: ...", action: nil, keyEquivalent: "")
    private let jobsItem = NSMenuItem(title: "Jobs: ...", action: nil, keyEquivalent: "")
    private let drafterItem = NSMenuItem(title: "DRAFTER", action: nil, keyEquivalent: "")
    private let writerItem = NSMenuItem(title: "WRITER", action: nil, keyEquivalent: "")
    private let judgeItem = NSMenuItem(title: "JUDGE", action: nil, keyEquivalent: "")
    private let repoRoot = "__REPO_ROOT__"
    private let dashboardURL = "http://127.0.0.1:8765"
    private var timer: Timer?

    func applicationDidFinishLaunching(_ notification: Notification) {
        guard let button = statusItem.button else { return }
        button.title = IndicatorState.idle.title

        productItem.isEnabled = false
        healthItem.isEnabled = false
        powerItem.isEnabled = false
        jobsItem.isEnabled = false
        drafterItem.isEnabled = false
        writerItem.isEnabled = false
        judgeItem.isEnabled = false

        menu.addItem(productItem)
        menu.addItem(healthItem)
        menu.addItem(powerItem)
        menu.addItem(jobsItem)
        menu.addItem(drafterItem)
        menu.addItem(writerItem)
        menu.addItem(judgeItem)
        menu.addItem(NSMenuItem.separator())
        menu.addItem(item("Open Dashboard", #selector(openDashboard)))
        menu.addItem(item("Restart Services", #selector(restartServices)))
        menu.addItem(item("Shutdown Services", #selector(shutdownServices)))
        menu.addItem(NSMenuItem.separator())
        menu.addItem(item("Quit", #selector(quitApp)))

        statusItem.menu = menu
        refreshHealth()
        timer = Timer.scheduledTimer(timeInterval: 5.0, target: self, selector: #selector(refreshHealth), userInfo: nil, repeats: true)
    }

    private func item(_ title: String, _ action: Selector) -> NSMenuItem {
        let m = NSMenuItem(title: title, action: action, keyEquivalent: "")
        m.target = self
        return m
    }

    private func runShell(_ command: String) {
        let process = Process()
        process.executableURL = URL(fileURLWithPath: "/bin/bash")
        process.arguments = ["-lc", "cd \"\(repoRoot)\" && \(command)"]
        process.standardOutput = Pipe()
        process.standardError = Pipe()
        try? process.run()
    }

    @objc private func refreshHealth() {
        guard let url = URL(string: "\(dashboardURL)/api/health") else { return }
        let task = URLSession.shared.dataTask(with: url) { data, response, _ in
            DispatchQueue.main.async {
                guard
                    let http = response as? HTTPURLResponse,
                    http.statusCode == 200,
                    let data = data,
                    let obj = try? JSONSerialization.jsonObject(with: data) as? [String: Any]
                else {
                    self.healthItem.title = "Health: dashboard down"
                    self.powerItem.title = "Power: unknown"
                    self.jobsItem.title = "Jobs: unknown"
                    self.statusItem.button?.title = IndicatorState.error.title
                    return
                }

                let power = (obj["power"] as? [String: Any]) ?? [:]
                let counts = (obj["counts"] as? [String: Any]) ?? [:]
                let system = (obj["system"] as? [String: Any]) ?? [:]
                let residentRoles = (system["residentRoles"] as? [[String: Any]]) ?? []
                let pending = counts["pending"] as? Int ?? 0
                let running = counts["running"] as? Int ?? 0
                let completed = counts["completed"] as? Int ?? 0
                let failed = counts["failed"] as? Int ?? 0
                let mode = (power["mode"] as? String) ?? "unknown"

                self.healthItem.title = "Health: dashboard up"
                self.powerItem.title = "Power: \(mode)"
                self.jobsItem.title = "Jobs: pending \(pending) | running \(running) | done \(completed) | failed \(failed)"
                self.statusItem.button?.title = running > 0 ? IndicatorState.working.title : IndicatorState.idle.title
                self.drafterItem.title = self.roleLine(label: "DRAFTER", role: residentRoles.first(where: { (($0["name"] as? String) ?? "").uppercased() == "DRAFTER" }) ?? [:])
                self.writerItem.title = self.roleLine(label: "WRITER", role: residentRoles.first(where: { (($0["name"] as? String) ?? "").uppercased() == "WRITER" }) ?? [:])
                self.judgeItem.title = self.roleLine(label: "JUDGE", role: residentRoles.first(where: { (($0["name"] as? String) ?? "").uppercased() == "JUDGE" }) ?? [:])
            }
        }
        task.resume()
    }

    @objc private func openDashboard() {
        NSWorkspace.shared.open(URL(string: dashboardURL)!)
    }

    @objc private func restartServices() {
        runShell("launchctl kickstart -k gui/$UID/com.amanoba.coursequality.caffeinate && launchctl kickstart -k gui/$UID/com.amanoba.coursequality.role.drafter && launchctl kickstart -k gui/$UID/com.amanoba.coursequality.role.writer && launchctl kickstart -k gui/$UID/com.amanoba.coursequality.role.judge && launchctl kickstart -k gui/$UID/com.amanoba.coursequality.worker && launchctl kickstart -k gui/$UID/com.amanoba.coursequality.dashboard && launchctl kickstart -k gui/$UID/com.amanoba.coursequality.watchdog")
    }

    @objc private func shutdownServices() {
        runShell("for label in com.amanoba.coursequality.worker com.amanoba.coursequality.dashboard com.amanoba.coursequality.watchdog com.amanoba.coursequality.ollama com.amanoba.coursequality.caffeinate com.amanoba.coursequality.role.drafter com.amanoba.coursequality.role.writer com.amanoba.coursequality.role.judge; do launchctl bootout \\\"gui/$UID/$label\\\" >/dev/null 2>&1 || true; done")
    }

    @objc private func quitApp() {
        NSApplication.shared.terminate(nil)
    }

    private func roleLine(label: String, role: [String: Any]) -> String {
        let status = (role["status"] as? String) ?? "unknown"
        let symbol: String
        switch status.lowercased() {
        case "healthy", "working", "available":
            symbol = "🟢"
        case "idle":
            symbol = "⚪"
        case "stalled", "degraded", "warning":
            symbol = "🟠"
        case "error", "unavailable", "failed":
            symbol = "🔴"
        default:
            symbol = "⚪"
        }
        return "\(symbol) \(label)"
    }
}

let app = NSApplication.shared
let delegate = AmanobaMenubarApp()
app.delegate = delegate
app.setActivationPolicy(.accessory)
app.run()
